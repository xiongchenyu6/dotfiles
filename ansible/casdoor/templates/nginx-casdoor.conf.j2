# Casdoor reverse proxy for {{ casdoor_domain }} (Cloudflare-fronted)

upstream casdoor_upstream {
    server 127.0.0.1:{{ casdoor_http_port }};
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name {{ casdoor_domain }};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ casdoor_domain }};

    include /etc/nginx/cloudflare-realip.conf;

    ssl_certificate     {{ casdoor_ssl_cert }};
    ssl_certificate_key {{ casdoor_ssl_key }};
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    client_max_body_size 64M;
    proxy_read_timeout   600s;
    proxy_send_timeout   600s;

    access_log /var/log/nginx/casdoor.access.log;
    error_log  /var/log/nginx/casdoor.error.log;

    location / {
        proxy_pass http://casdoor_upstream;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;

        proxy_buffering off;
        proxy_redirect  off;
    }
}

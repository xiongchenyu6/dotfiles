# Sub2API reverse proxy for {{ sub2api_domain }}

upstream sub2api_backend { server 127.0.0.1:{{ sub2api_server_port }}; keepalive 16; }

server {
    listen 80;
    listen [::]:80;
    server_name {{ sub2api_domain }};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ sub2api_domain }};

    ssl_certificate     {{ sub2api_ssl_cert }};
    ssl_certificate_key {{ sub2api_ssl_key }};
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    access_log /var/log/nginx/sub2api.access.log;
    error_log  /var/log/nginx/sub2api.error.log;

    client_max_body_size 100M;

    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Forwarded-Host  $host;
    proxy_http_version 1.1;
    proxy_set_header Connection "";

    # SSE / long-lived streaming responses (LLM completions)
    proxy_buffering    off;
    proxy_read_timeout 1h;
    proxy_send_timeout 1h;

    location / {
        proxy_pass http://sub2api_backend;
    }
}

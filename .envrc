watch_file ./shell/default.nix
# Disable ca-derivations for devShell to avoid hash mismatch errors
export NIX_CONFIG="experimental-features = nix-command flakes"
# oracle-amd-002's hermes-agent pulls in nodejs-20 (EOL, marked insecure) via
# hermes-tui's npmDeps. hermes-agent instantiates its own pkgs with default
# config, so nixpkgs.config.permittedInsecurePackages can't reach it — the env
# var (honored under nixos-rebuild's --impure) is the only working lever.
export NIXPKGS_ALLOW_INSECURE=1
use flake .
